# ─── Admin ────────────────────────────────────────────────────────────────────
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=admin123

# ─── Google Analytics ─────────────────────────────────────────────────────────
VITE_GA_ID=G-XXXXXXX

# ─── EmailJS (https://emailjs.com — gratuit jusqu'à 200 emails/mois) ─────────
# 1. Créer un compte sur emailjs.com
# 2. Ajouter un service Gmail avec maw106277@gmail.com → noter le Service ID
# 3. Créer un template "client" (variables : to_email, to_name, booking_id,
#    pack_name, booking_date, number_of_people, total_amount,
#    payment_method, payment_status) → noter le Template ID
# 4. Créer un template "admin" (variables : booking_id, customer_name,
#    customer_email, customer_phone, pack_name, booking_date,
#    number_of_people, total_amount, payment_method) → noter le Template ID
# 5. Récupérer votre Public Key dans Account > API Keys
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
VITE_EMAILJS_CUSTOMER_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_ADMIN_TEMPLATE_ID=template_xxxxxxx
